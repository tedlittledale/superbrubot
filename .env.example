# --- Telegram ---
# Create a bot with @BotFather (/newbot), it gives you this token.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# The group chat id. Add the bot to your group, then run `npm run test:telegram`
# which prints the chat id of any chat that has messaged the bot.
# Group ids are negative, e.g. -1001234567890
TELEGRAM_CHAT_ID=-1001234567890

# --- Superbru ---
SUPERBRU_EMAIL=you@example.com
SUPERBRU_PASSWORD=your-password

# Your World Cup pool id (from the pool URL ?p=...). "Twelve years no poo" = 13208945.
SUPERBRU_POOL_ID=13208945

# Dashboard entry point (used to establish the logged-in session).
SUPERBRU_POOL_URL=https://www.superbru.com/player/dashboard.php

# --- Session persistence (avoid logging in on every restart) ---
# The bot saves its logged-in session to <STATE_DIR>/auth/state.json and reuses
# it. Pick ONE of these so the session survives Railway restarts:
#
# A) Volume (best): mount a Railway volume and point STATE_DIR at it. The session
#    is read AND written there, so it self-refreshes and rarely re-logs-in.
# STATE_DIR=/data
#
# B) No volume: run `npm run login` locally to log in once, then paste the value
#    it prints here and into Railway. The bot seeds the session from it on boot,
#    so it never logs in from a datacenter IP. Re-run when the session expires.
# SUPERBRU_STATE_B64=

# --- Behaviour ---
# Minutes after kickoff to send. 0 = at kickoff (when predicted scores unlock).
# The tick retries each minute until scores are revealed, so 0 is fine.
SEND_OFFSET_MINUTES=0

# How long after the send time a fixture stays eligible (catches missed ticks /
# downtime, and gives scores time to reveal). Minutes.
SEND_WINDOW_MINUTES=120

# --- End-of-day summary ---
# Once every match on a US calendar day has had its result posted, a recap of the
# points everyone gained that day is sent. Matches are bucketed by this timezone;
# Pacific keeps the late evening game (which finishes after midnight UK/Eastern)
# on the same US day it belongs to. Set DAILY_SUMMARY=0 to turn the recap off.
# SUMMARY_TZ=America/Los_Angeles
# DAILY_SUMMARY=1
